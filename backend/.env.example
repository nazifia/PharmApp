# ─────────────────────────────────────────────────────────────────────────────
# PharmApp Backend — Production Environment Template
# Copy to .env and fill in real values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# Which settings module to load
DJANGO_SETTINGS_MODULE=pharmapi.settings.prod

# ── Django core (ALL required in production) ──────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-long-random-secret-key-here

# Comma-separated hostnames that Django will serve (no scheme, no port)
# Example: api.mypharmapp.com,www.mypharmapp.com
DJANGO_ALLOWED_HOSTS=api.mypharmapp.com

# ── Database (MySQL in production) ────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql://pharmapp_user:strong-password@db.mypharmapp.com:3306/pharmapp_prod

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated full origins (scheme + host + optional port) allowed to call the API
# Example: https://mypharmapp.com,https://app.mypharmapp.com
CORS_ALLOWED_ORIGINS=https://pharmapp505020.web.app,https://pharmapp505020.firebaseapp.com

# ── Optional / future ─────────────────────────────────────────────────────────
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@mypharmapp.com

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
