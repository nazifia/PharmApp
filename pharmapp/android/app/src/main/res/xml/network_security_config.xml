<?xml version="1.0" encoding="utf-8"?>
<!--
  Production network security config — HTTPS only.
  Debug builds override this via src/debug/res/xml/network_security_config.xml
  which allows cleartext HTTP for LAN/emulator development.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
