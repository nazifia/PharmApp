<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for PharmApp development/testing.

  base-config allows cleartext (HTTP) to any host so the API base URL
  configured via the in-app Settings screen works on any LAN IP.
  Production builds should restrict this to HTTPS only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
