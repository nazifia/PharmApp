<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for PharmApp development/testing.

  Allows cleartext (HTTP) traffic to:
    - 10.0.2.2       Android emulator → host machine (localhost:8000)
    - 10.0.3.2       Genymotion emulator → host machine
    - 192.168.x.x    LAN subnet (physical device on same network as Django server)
    - localhost      Loopback (should not be needed on device, but harmless)

  Production builds should remove this and use HTTPS only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator → host localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Genymotion emulator → host localhost -->
        <domain includeSubdomains="false">10.0.3.2</domain>
        <!-- Physical device on LAN (adjust to match your server IP) -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <!-- Loopback -->
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
