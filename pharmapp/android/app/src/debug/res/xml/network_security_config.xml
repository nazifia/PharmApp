<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config — allows cleartext HTTP so the app can
  reach the local Django dev server (http://10.0.2.2:8000 on emulator or any
  LAN IP configured via the in-app Settings screen).
  This file overrides src/main/res/xml/network_security_config.xml in debug builds only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
